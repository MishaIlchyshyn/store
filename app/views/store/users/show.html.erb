<%= link_to "← All users", store_users_path, class: "text-sm text-indigo-600 hover:text-indigo-800 mb-6 inline-block" %>

<div class="bg-white rounded-xl border border-gray-200 p-6 mb-4">
  <h1 class="text-2xl font-bold text-gray-900 mb-1"><%= @user.full_name %></h1>
  <p class="text-gray-500 text-sm"><%= @user.email_address %></p>

  <div class="flex items-center gap-3 mt-5">
    <%= link_to "Edit user", edit_store_user_path(@user), class: "border border-indigo-600 text-indigo-600 px-3 py-1.5 rounded-md text-sm hover:bg-indigo-50" %>
    <%= button_to "Delete user", store_user_path(@user), method: :delete,
          data: { turbo_confirm: "Are you sure?" },
          class: "bg-red-600 text-white px-3 py-1.5 rounded-md text-sm hover:bg-red-700 cursor-pointer" %>
  </div>
</div>
