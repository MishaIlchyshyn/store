<%= content_for :content do %>
  <div class="flex gap-8">
    <nav class="w-48 shrink-0">
      <h4 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2">Account Settings</h4>
      <%= link_to "Profile", settings_profile_path, class: "block py-1.5 text-sm text-gray-700 hover:text-indigo-600" %>
      <%= link_to "Password", settings_password_path, class: "block py-1.5 text-sm text-gray-700 hover:text-indigo-600" %>

      <% if Current.user.admin? %>
        <h4 class="text-xs font-semibold uppercase tracking-wider text-gray-400 mb-2 mt-6">Store Settings</h4>
        <%= link_to "Users", store_users_path, class: "block py-1.5 text-sm text-gray-700 hover:text-indigo-600" %>
        <%= link_to "Products", store_products_path, class: "block py-1.5 text-sm text-gray-700 hover:text-indigo-600" %>
        <%= link_to "Wishlists", store_wishlists_path, class: "block py-1.5 text-sm text-gray-700 hover:text-indigo-600" %>
        <%= link_to "Subscribers", store_subscribers_path, class: "block py-1.5 text-sm text-gray-700 hover:text-indigo-600" %>
      <% end %>
    </nav>

    <div class="flex-1 min-w-0">
      <%= yield %>
    </div>
  </div>
<% end %>

<%= render template: "layouts/application" %>
