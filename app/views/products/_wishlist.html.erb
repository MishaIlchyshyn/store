<% if authenticated? %>
  <%= form_with url: product_wishlist_path(product), class: "flex items-center gap-2" do |form| %>
    <% if Current.user.wishlists.any? %>
      <%= form.collection_select :wishlist_id, Current.user.wishlists, :id, :name, {},
            class: "rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    <% end %>
    <%= form.submit "Add to wishlist", class: "bg-white border border-indigo-600 text-indigo-600 px-4 py-2 rounded-md text-sm font-medium hover:bg-indigo-50 cursor-pointer" %>
  <% end %>
<% else %>
  <%= link_to "Add to wishlist", sign_up_path, class: "inline-block border border-indigo-600 text-indigo-600 px-4 py-2 rounded-md text-sm font-medium hover:bg-indigo-50" %>
<% end %>
